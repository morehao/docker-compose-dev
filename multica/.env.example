# ============================================
# Multica 自托管部署环境变量
# ============================================

# --- 数据库 ---
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=changeme

# --- 服务端口 ---
BACKEND_PORT=8080
FRONTEND_PORT=3000

# --- 跨域/公网配置 ---
# 如果通过公网 IP 访问，取消注释并修改为实际 IP
# FRONTEND_ORIGIN=http://49.232.218.218:3000
# CORS_ALLOWED_ORIGINS=http://49.232.218.218:3000

# --- JWT 密钥（必须修改！） ---
JWT_SECRET=change-me-in-production

# --- 环境模式 ---
# production: 生产模式，无固定验证码，需配置邮件服务
# development: 开发模式，可使用固定验证码 MULTICA_DEV_VERIFICATION_CODE
APP_ENV=production

# --- 开发验证码（仅 APP_ENV=development 时生效） ---
# 取消注释后可用 888888 作为固定验证码登录（无需邮件服务）
# MULTICA_DEV_VERIFICATION_CODE=888888

# --- 邮件服务（二选一） ---
# 选项 A: Resend (SaaS)
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=noreply@multica.ai

# 选项 B: SMTP 中继（优先级高于 Resend）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=25
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=
# SMTP_TLS_INSECURE=false

# --- Google OAuth ---
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- S3 兼容存储（文件附件） ---
# S3_BUCKET=my-bucket
# S3_REGION=us-west-2
# AWS_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# ATTACHMENT_DOWNLOAD_MODE=auto

# --- 注册控制 ---
ALLOW_SIGNUP=true
# ALLOWED_EMAILS=user1@example.com,user2@example.com
# ALLOWED_EMAIL_DOMAINS=example.com
# DISABLE_WORKSPACE_CREATION=true

# --- 镜像标签（默认 latest，可固定版本如 v0.2.4） ---
# MULTICA_IMAGE_TAG=latest

# --- 高级 ---
# MULTICA_PUBLIC_URL=https://api.example.com
# MULTICA_TRUSTED_PROXIES=127.0.0.1/32
# MULTICA_FEATURE_FLAGS_FILE=

# ============================================
# 使用说明
# ============================================
# 1. cp .env.example .env（.env 已加入 .gitignore，不会提交）
# 2. 至少修改 JWT_SECRET 和 POSTGRES_PASSWORD
# 3. 如需公网访问，取消注释 FRONTEND_ORIGIN / CORS_ALLOWED_ORIGINS
# 4. 如无邮件服务，可设置 APP_ENV=development + MULTICA_DEV_VERIFICATION_CODE=888888
# 5. docker compose up -d
